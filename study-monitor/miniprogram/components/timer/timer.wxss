.timer-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

/* 圆形进度条 */
.timer-circle {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 40rpx;
}

.circle-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f0f0f0;
}

.circle-progress {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: conic-gradient(
    #4A90D9 0%,
    #4A90D9 calc(var(--progress) * 1%),
    transparent calc(var(--progress) * 1%),
    transparent 100%
  );
  mask: radial-gradient(transparent 170rpx, #000 171rpx);
  -webkit-mask: radial-gradient(transparent 170rpx, #000 171rpx);
}

.timer-inner {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.timer-time {
  font-size: 80rpx;
  font-weight: 300;
  color: #333;
  font-variant-numeric: tabular-nums;
}

.timer-label {
  font-size: 28rpx;
  color: #999;
}

/* 模式切换 */
.mode-switch {
  display: flex;
  gap: 20rpx;
  background: #f5f5f5;
  padding: 8rpx;
  border-radius: 16rpx;
}

.mode-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 40rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.mode-item.active {
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.mode-item text:first-child {
  font-size: 28rpx;
  color: #333;
}

.mode-duration {
  font-size: 22rpx;
  color: #999;
}
