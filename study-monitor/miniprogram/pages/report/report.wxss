.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* 日期选择器 */
.date-selector {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 30rpx;
  padding: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.date-nav {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  border-radius: 50%;
  font-size: 28rpx;
  color: #666;
}

.date-range {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.date-today {
  padding: 8rpx 20rpx;
  background: #E3F2FD;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #1976D2;
}

/* 概览卡片 */
.summary-card {
  margin-bottom: 24rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  overflow: hidden;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  overflow: hidden;
  min-width: 0;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #4A90D9;
  line-height: 1.2;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

/* 图表卡片 */
.chart-card {
  margin-bottom: 24rpx;
}

.chart-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.chart-container {
  padding: 20rpx 0;
}

/* 柱状图 */
.bar-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 300rpx;
  padding: 0;
  box-sizing: border-box;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.bar-wrapper {
  width: 40rpx;
  height: 200rpx;
  background: #f0f0f0;
  border-radius: 8rpx 8rpx 0 0;
  display: flex;
  align-items: flex-end;
}

.bar-label {
  font-size: 24rpx;
  color: #666;
}

.bar-value {
  font-size: 20rpx;
  color: #999;
}

/* 折线图 */
.line-chart {
  position: relative;
  height: 280rpx;
  padding: 0 10rpx;
  box-sizing: border-box;
}

/* 网格线 */
.grid-lines {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  top: 10rpx;
  bottom: 50rpx;
  pointer-events: none;
}

.grid-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background: #eee;
}

/* 连线 */
.line-connector {
  position: absolute;
  height: 3rpx;
  transform-origin: left center;
  transition: all 0.5s ease;
}

.line-connector.up {
  background: #27AE60;
}

.line-connector.down {
  background: #E74C3C;
}

.line-connector.flat {
  background: #999;
}

/* 数据点容器 */
.line-dots {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  top: 10rpx;
  bottom: 50rpx;
}

.line-dot-wrapper {
  position: absolute;
  transform: translate(-50%, 50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.line-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.15);
}

.line-dot.eff-high {
  background: #27AE60;
}

.line-dot.eff-mid {
  background: #4A90D9;
}

.line-dot.eff-low {
  background: #E74C3C;
}

.line-dot-value {
  font-size: 20rpx;
  color: #666;
  font-weight: 600;
  margin-top: 2rpx;
}

/* 底部标签 */
.line-labels {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  bottom: 10rpx;
  display: flex;
  justify-content: space-between;
}

.line-label {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  flex: 1;
}

/* 柱状图补充 */
.bar-empty {
  background: #e0e0e0 !important;
  min-height: 4rpx;
}

.bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #4A90D9 0%, #64B5F6 100%);
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.6s ease;
  min-height: 4rpx;
}

.text-muted {
  color: #ccc !important;
}

.no-data {
  padding: 60rpx 0;
  text-align: center;
  color: #ccc;
  font-size: 26rpx;
}

/* 姿势质量评分 */
.posture-quality {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.pq-main {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.pq-score {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
}

.pq-unit {
  font-size: 28rpx;
  color: #999;
}

.pq-label {
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 12rpx;
}

.pq-details {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999;
}

/* 分心统计 */
.distraction-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.distraction-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.distraction-icon {
  font-size: 36rpx;
}

.distraction-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.distraction-name {
  font-size: 26rpx;
  color: #333;
}

.distraction-detail {
  font-size: 22rpx;
  color: #999;
}

.distraction-bar {
  width: 100%;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.distraction-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.6s ease, background 0.6s ease;
}

.distraction-count-wrapper {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  min-width: 80rpx;
}

.distraction-count {
  font-size: 26rpx;
  font-weight: 600;
}

.distraction-percent {
  font-size: 20rpx;
  color: #999;
}

/* 建议区域 */
.advice-section {
  margin-bottom: 24rpx;
}

.advice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.advice-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.advice-icon {
  font-size: 36rpx;
}

.advice-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.advice-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #E65100;
}

.advice-item-text {
  font-size: 24rpx;
  color: #BF360C;
  line-height: 1.6;
  word-break: break-all;
}

/* 学习方法 */
.methods-section {
  margin-bottom: 24rpx;
}

.method-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.method-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  box-sizing: border-box;
  overflow: hidden;
  border-left: 6rpx solid #4A90D9;
}

.method-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.method-index {
  width: 36rpx;
  height: 36rpx;
  background: #4A90D9;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.method-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.method-reason {
  font-size: 24rpx;
  color: #E65100;
  line-height: 1.6;
  word-break: break-all;
  padding-left: 8rpx;
  border-left: 3rpx solid #F39C12;
}

.method-steps {
  font-size: 24rpx;
  color: #666;
  line-height: 1.7;
  word-break: break-all;
}

.method-suitable {
  font-size: 22rpx;
  color: #999;
}
