.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.status-indicator {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  color: #999;
}

.status-indicator.active {
  color: #27AE60;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ccc;
}

.status-indicator.active .status-dot {
  background: #27AE60;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.plan-selector {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.plan-selector .arrow {
  font-size: 24rpx;
  color: #999;
}

/* 计时器区域 */
.timer-section {
  margin-bottom: 30rpx;
}

/* 摄像头区域 */
.camera-section {
  position: relative;
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  background: #000;
}

.camera-preview {
  width: 100%;
  height: 100%;
}

.camera-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
}

.camera-indicator {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

.camera-indicator.focus {
  background: rgba(39, 174, 96, 0.8);
}

.camera-indicator.look_away,
.camera-indicator.head_down {
  background: rgba(243, 156, 18, 0.8);
}

.camera-indicator.face_lost,
.camera-indicator.eye_close {
  background: rgba(231, 76, 60, 0.8);
}

.camera-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a1a1a;
}

.camera-placeholder text {
  color: #999;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.btn-authorize {
  margin-top: 20rpx;
  padding: 12rpx 32rpx;
  background: #4A90D9;
  color: #fff;
  font-size: 26rpx;
  border-radius: 8rpx;
  border: none;
}

/* 控制按钮 */
.controls {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.btn-start {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #27AE60 0%, #219A52 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.btn-start.running {
  background: linear-gradient(135deg, #F39C12 0%, #E67E22 100%);
}

.btn-reset {
  width: 200rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  color: #666;
  font-size: 28rpx;
  border-radius: 16rpx;
  border: none;
}

.btn-reset[disabled] {
  opacity: 0.5;
}

/* 今日统计 */
.today-stats {
  margin-bottom: 30rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #4A90D9;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 建议卡片 */
.advice-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}

.advice-icon {
  font-size: 48rpx;
}

.advice-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.advice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #E65100;
}

.advice-text {
  font-size: 24rpx;
  color: #BF360C;
  line-height: 1.6;
}

/* 计划选择弹窗 */
.plan-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.plan-picker {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.plan-picker.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.picker-header text:last-child {
  color: #999;
  font-size: 28rpx;
  font-weight: normal;
}

.picker-list {
  max-height: 600rpx;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-item.selected {
  background: #E3F2FD;
  border-radius: 12rpx;
}

.picker-item-title {
  font-size: 30rpx;
  color: #333;
}

.picker-item-duration {
  font-size: 26rpx;
  color: #999;
}

.picker-empty {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.picker-empty .link {
  color: #4A90D9;
  font-size: 28rpx;
}

/* 模拟器提示 */
.simulator-tip {
  padding: 20rpx;
  background: #FFF3E0;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.simulator-tip text {
  font-size: 26rpx;
  color: #F39C12;
}
