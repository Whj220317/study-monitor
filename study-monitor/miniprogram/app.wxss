/* 全局样式 */
page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  overflow: hidden;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  border: none;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background: #f0f0f0;
  color: #666666;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  border: none;
  text-align: center;
}

.btn-danger {
  background: linear-gradient(135deg, #E74C3C 0%, #C0392B 100%);
  color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  border: none;
  text-align: center;
}

/* 标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #eeeeee;
  margin: 20rpx 0;
}

/* 状态颜色 */
.status-focus {
  color: #27AE60;
}

.status-distract {
  color: #E74C3C;
}

.status-break {
  color: #F39C12;
}

.status-leave {
  color: #95A5A6;
}
